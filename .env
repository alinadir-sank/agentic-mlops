# =============================================================================
# MLOps Multi-Agent System — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Ollama (local LLM inference)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------
# For local PersistentClient (default): just set the path
CHROMA_PERSIST_DIR=./rag_data

# For remote ChromaDB server: set host + port
# CHROMA_HOST=chroma.internal.yourdomain.com
# CHROMA_PORT=8000

# ---------------------------------------------------------------------------
# Metrics data source
# Select one: prometheus | azure | mlflow
# ---------------------------------------------------------------------------
METRICS_SOURCE=prometheus

# Default model/environment (used when not passed via CLI)
DEFAULT_MODEL_ID=fraud-classifier-v2
DEFAULT_ENVIRONMENT=production
METRICS_WINDOW_MINUTES=15

# ---------------------------------------------------------------------------
# Prometheus
# ---------------------------------------------------------------------------
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090
# PROMETHEUS_BEARER_TOKEN=
PROMETHEUS_MODEL_LABEL=model_id

# ---------------------------------------------------------------------------
# Azure Monitor / Azure ML
# ---------------------------------------------------------------------------
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_MONITOR_WORKSPACE_ID=
# AZURE_ML_WORKSPACE_NAME=

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
# MLFLOW_TRACKING_URI=http://mlflow.svc:5000
# MLFLOW_EXPERIMENT_NAME=production-model-evals
# MLFLOW_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Severity thresholds (all optional — defaults shown)
# ---------------------------------------------------------------------------
THRESHOLD_ACCURACY_CRITICAL=0.65
THRESHOLD_ACCURACY_MAJOR=0.72
THRESHOLD_ACCURACY_MINOR=0.80
THRESHOLD_DRIFT_CRITICAL=0.60
THRESHOLD_DRIFT_MAJOR=0.35
THRESHOLD_DRIFT_MINOR=0.20
THRESHOLD_LATENCY_CRITICAL_MS=2000
THRESHOLD_LATENCY_MAJOR_MS=1000
THRESHOLD_ERROR_RATE_CRITICAL=0.10
THRESHOLD_ERROR_RATE_MAJOR=0.05

# ---------------------------------------------------------------------------
# RAG retrieval parameters
# ---------------------------------------------------------------------------
RAG_SIMILAR_INCIDENTS=5
RAG_SIMILAR_RUNBOOKS=3
RAG_TREND_SNAPSHOTS=10
TREND_WINDOW_SIZE=20

# ---------------------------------------------------------------------------
# GitHub (for issue creation and retraining workflow dispatch)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-mlops-repo
GITHUB_RETRAIN_WORKFLOW_ID=retrain.yml
GITHUB_DEFAULT_BRANCH=main
GITHUB_ISSUE_LABELS=mlops,auto
# GITHUB_ISSUE_ASSIGNEES=on-call-engineer

# ---------------------------------------------------------------------------
# Kubernetes (for rollback and scale actions)
# ---------------------------------------------------------------------------
K8S_NAMESPACE=ml-production
# KUBECONFIG=/home/appuser/.kube/config  # omit for in-cluster
K8S_MAX_REPLICAS=20
# K8S_DEPLOYMENT_NAME_TEMPLATE={model_id}-{environment}
# HELM_RELEASE_NAME_TEMPLATE={model_id}-{environment}

# ---------------------------------------------------------------------------
# Slack notifications
# ---------------------------------------------------------------------------
SLACK_NOTIFICATIONS_ENABLED=true

# Option A: Incoming Webhook (simpler)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# Option B: Bot Token (for channel routing by severity)
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
# SLACK_DEFAULT_CHANNEL=#mlops-alerts
# SLACK_SEVERITY_CHANNELS={"critical":"#incidents","major":"#mlops-alerts","minor":"#mlops-info"}

# ---------------------------------------------------------------------------
# Email alerts
# ---------------------------------------------------------------------------
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_MIN_SEVERITY=major   # only email for major and critical

# SMTP (default)
ALERT_EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=mlops-alerts@yourdomain.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=mlops-alerts@yourdomain.com
EMAIL_TO_CRITICAL=oncall@yourdomain.com,cto@yourdomain.com
EMAIL_TO_MAJOR=ml-team@yourdomain.com
EMAIL_TO_MINOR=ml-team@yourdomain.com

# SendGrid (alternative)
# ALERT_EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Human-in-the-loop
# ---------------------------------------------------------------------------
HUMAN_IN_THE_LOOP=true   # set false to auto-approve major incidents

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
MODEL_VERSION=unknown   # override if Prometheus source can't fetch from registry


DRY_RUN=true  # set true to simulate actions without making changes (for testing)
